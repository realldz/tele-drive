# ════════════════════════════════════════════════════════════════════════════
# HOST-GO env — data-plane host (docker-compose.transfer.yml)
# ════════════════════════════════════════════════════════════════════════════
# Copy to `.env.transfer` on the Go data-plane host and fill in. This host runs
# the Go transfer service, its self-hosted Telegram Local Bot API, and the
# fast-path nginx (:8088 internal). The control plane runs on a SEPARATE host
# (see .env.core.example).
#
# Usage:  docker compose --env-file .env.transfer -f docker-compose.transfer.yml up -d
#
# Bring up the CORE host FIRST — the Go service blocks up to 60s waiting for the
# core gRPC server on CORE_HOST:50051.

# ─── Cross-host wiring (REQUIRED) ─────────────────────────────────────────────
# CORE_HOST — host/IP of the control-plane host, reachable over the PRIVATE
#   network. Used two ways on this host:
#     - NESTJS_GRPC_URL = dns:///${CORE_HOST}:50051         (Go → NestJS gRPC)
#     - REDIS_URL       = redis://...@${CORE_HOST}:6379     (shared Redis)
#   Must match a SAN entry on the core leaf cert (re-issue certs before splitting).
CORE_HOST=10.0.0.1

# GO_PRIVATE_IP — the private-NIC IP THIS host binds the Go service ports to.
#   NEVER 0.0.0.0 (that would expose the data plane to the public LAN). Both the
#   HTTP data plane (3001) and the gRPC server (50051) bind only here:
#     - 3001  ← edge nginx on CORE_HOST proxies /files/*, S3 object I/O; NestJS
#               posts purge requests. Firewall to CORE_HOST.
#     - 50051 ← NestJS dials this over gRPC (mTLS). Firewall to CORE_HOST.
GO_PRIVATE_IP=10.0.0.2

# UPLOAD_BUFFER_NFS — path to the shared upload buffer, mounted on BOTH hosts.
#   Go writes chunks here; NestJS (CORE_HOST) deletes them on abort/delete. Use
#   the SAME NFS export on both hosts so download-while-draining can read chunks
#   another upload buffered.
UPLOAD_BUFFER_NFS=/mnt/tele-drive-buffer

# ─── Redis password (REQUIRED) ───────────────────────────────────────────────
# MUST equal REDIS_PASSWORD on the CORE host — the Go service authenticates to
# the core host's Redis across the private network with this value.
REDIS_PASSWORD=change-this-to-a-strong-random-secret

# ─── Telegram Local Bot API (REQUIRED) ────────────────────────────────────────
# Get from https://my.telegram.org. The telegram-bot-api container will not become
# healthy without both. The bot API runs on THIS host so Telegram traffic never
# crosses the inter-host link.
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# ─── Standalone transfer domain (cross-origin) ───────────────────────────────
# Set these ONLY when the Go data plane serves a separate public domain from the
# app/frontend (e.g. app on app.example.com, transfer on dl.example.com). Left
# unset they default to today's single-origin behavior (CORS reflect-any, cookie
# SameSite=Strict) — safe for same-origin/dev.
#
# CORS_ORIGIN — comma-separated allow-list of app origins permitted to call the
#   Go service with credentials. MUST be explicit in this cross-origin setup: a
#   literal "*" is invalid with credentials, so unset/"*" makes the service
#   reflect the request origin instead (fine for dev, NOT for a public split).
# CORS_ORIGIN=https://app.example.com,https://admin.example.com
#
# STREAM_COOKIE_SAMESITE — strict|lax|none. The stream cookie must ride cross-site
#   media/download requests from the app page to this transfer domain, which
#   SameSite=Strict blocks. Set "none" (always paired with Secure → HTTPS only)
#   when app and transfer domains differ. Default "strict".
# STREAM_COOKIE_SAMESITE=none

# ─── Public transfer origin (nginx-public service) ───────────────────────────
# TRANSFER_DOMAIN — the standalone public domain the Go data plane serves on THIS
#   host (e.g. dl.example.com). The nginx-public service terminates TLS for it on
#   :443 and proxies /files/*, /transfer/*, /public/* to backend-transfer:3001.
#   Clients hit this host DIRECTLY — no cross-host hop through the core edge nginx.
#
#   DNS: create an A/AAAA record TRANSFER_DOMAIN → this host's PUBLIC IP.
#   MUST differ from S3_DOMAIN — the S3 SigV4 host filter only gates /:bucket/*
#   object routes, not the /v1/transfer/* routes served here, but keeping the two
#   domains distinct avoids any host-based routing ambiguity.
#   Also set CORS_ORIGIN above to the app origin(s) so browsers can call this
#   cross-origin domain with credentials.
TRANSFER_DOMAIN=dl.example.com

# SSL_CERT_FILE / SSL_KEY_FILE — filenames (NOT paths) of the TLS cert + key for
#   TRANSFER_DOMAIN, read from ./nginx/ssl inside the nginx-public container.
#   Production: mount a real CA/Let's Encrypt cert here. If absent, the entrypoint
#   self-signs a fallback for TRANSFER_DOMAIN (dev/first-boot only — browsers warn).
#   Firewall: only nginx-public :80/:443 face the internet; backend-transfer 3001
#   and gRPC 50051 stay bound to GO_PRIVATE_IP (private NIC).
SSL_CERT_FILE=cert.pem
SSL_KEY_FILE=key.pem

# ─── Optional ─────────────────────────────────────────────────────────────────
# S3_DOMAIN — host filter for the S3 data-plane routes. Must match backend/.env
#   and the CORE host. Leave default unless using S3.
# S3_DOMAIN=s3.example.com
# MAX_BUFFER_FILE_SIZE — files at/below this size buffer to disk; larger stream
#   straight to Telegram. Keep in sync with NestJS MAX_BUFFER_FILE_SIZE. Default 50MiB.
# MAX_BUFFER_FILE_SIZE=52428800
# UPLOAD_OUTSTANDING_TTL — self-heal ceiling for the per-file chunked-upload
#   outstanding counter (Redis upload:outstanding:*). Re-armed on every chunk, so it
#   only caps leakage from a crashed instance mid-drain. Go duration (e.g. 6h, 90m).
#   Raise it if legitimately huge/slow uploads can stay outstanding longer. Default 6h.
# UPLOAD_OUTSTANDING_TTL=6h
