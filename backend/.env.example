# PostgreSQL Connection String
DATABASE_URL="postgresql://tele_drive:tele_drive@localhost:5432/tele_drive"

# ─── Telegram Bot ────────────────────────────────────────────────────
# Main bot token (get from @BotFather)
TELEGRAM_BOT_TOKEN="your-bot-token-here"

# ID of the private Channel/Group used for file storage
# Add bot to the group as Admin, then use @RawDataBot to get the chat ID
TELEGRAM_CHAT_ID="-100xxxxxxxxxx"

# Optional: Telegram Local Bot API Server URL
# If running a Local Bot API Server, uncomment:
# TELEGRAM_API_ROOT=http://localhost:8081

# Optional: Extra upload bots (comma-separated tokens)
# Each bot adds ~18 msg/min upload capacity. All bots must be admin in TELEGRAM_CHAT_ID.
# Bot identity is tracked by Telegram numeric bot ID (from getMe()), so changing
# the order of tokens here will NOT break existing file downloads.
# TELEGRAM_UPLOAD_BOT_TOKENS=bot1_token,bot2_token

# Optional: Rate limit per bot — max sendDocument calls per minute (default: 18)
# TELEGRAM_SEND_RATE_LIMIT=18

# ─── Security ────────────────────────────────────────────────────────
# JWT secret for signing authentication tokens (change in production!)
JWT_SECRET="change-this-to-a-random-secret"

# Master secret for AES-256-CTR file encryption (MUST be exactly 32 characters)
MASTER_SECRET="change-this-to-32-byte-secret!!"

# ─── Optional ────────────────────────────────────────────────────────
# Max chunk size in bytes (default: ~19MB, max ~2GB with Local Bot API)
# MAX_CHUNK_SIZE=2040109465

# Server port (default: 3001)
# PORT=3001

# ─── Logging ─────────────────────────────────────────────────────────
# Log level: debug, http, info, warn, error (default: debug in dev, info in prod)
# LOG_LEVEL=debug

# Node environment: development, production (default: development)
# NODE_ENV=development

# Log directory (default: backend/.logs)
# LOG_DIR=.logs

# ─── Backend Redesign (gRPC + Go Transfer) ──────────────────────────
# S3 domain for 307 redirect (download + upload).
# Must match S3_DOMAIN in root .env and nginx config.
# In Docker Compose this is set via compose args; for local dev use "localhost".
# S3_DOMAIN=localhost

# Phase 4: Enable event-driven delete via Redis Pub/Sub.
# When "true", NestJS publishes DELETE_FILE events to Redis; Go handles Telegram deletion.
# When "false" or unset, NestJS calls Go's HTTP purge endpoint directly (legacy).
# ENABLE_EVENT_DRIVEN_DELETE=true

# Phase 6: Enable S3 PUT redirect (307 from NestJS to Go).
# When "true", S3 PutObject/UploadPart are redirected to Go via one-time tokens.
# When "false" or unset, NestJS streams binary data through itself (legacy).
# ENABLE_S3_PUT_REDIRECT=true

# Go Transfer service gRPC URL (NestJS calls Go's TransferService).
# In Docker: backend-transfer:50051. For local dev: localhost:50051.
# GO_TRANSFER_GRPC_URL=localhost:50051

# Set to "false" for backend-core (NestJS). Set to "true" for backend-transfer (Go/NestJS transfer mode).
# IS_TRANSFER_SERVICE=false
