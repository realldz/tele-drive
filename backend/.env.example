# SQLite Connection String
DATABASE_URL="file:./dev.db"

# ─── Telegram Bot ────────────────────────────────────────────────────
# Main bot token (get from @BotFather)
TELEGRAM_BOT_TOKEN="your-bot-token-here"

# ID of the private Channel/Group used for file storage
# Add bot to the group as Admin, then use @RawDataBot to get the chat ID
TELEGRAM_CHAT_ID="-100xxxxxxxxxx"

# Optional: Telegram Local Bot API Server URL
# If running a Local Bot API Server, uncomment:
# TELEGRAM_API_ROOT=http://localhost:8081

# Optional: Extra upload bots (comma-separated tokens)
# Each bot adds ~18 msg/min upload capacity. All bots must be admin in TELEGRAM_CHAT_ID.
# TELEGRAM_UPLOAD_BOT_TOKENS=bot1_token,bot2_token

# Optional: Rate limit per bot — max sendDocument calls per minute (default: 18)
# TELEGRAM_SEND_RATE_LIMIT=18

# ─── Security ────────────────────────────────────────────────────────
# JWT secret for signing authentication tokens (change in production!)
JWT_SECRET="change-this-to-a-random-secret"

# Master secret for AES-256-CTR file encryption (MUST be exactly 32 characters)
MASTER_SECRET="change-this-to-32-byte-secret!!"

# ─── Optional ────────────────────────────────────────────────────────
# Max chunk size in bytes (default: ~19MB, max ~2GB with Local Bot API)
# MAX_CHUNK_SIZE=2040109465

# Server port (default: 3001)
# PORT=3001
