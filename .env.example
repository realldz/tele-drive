# ─── Telegram Local Bot API Server ────────────────────────────────────
# Required for Docker deployment. Get from https://my.telegram.org
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# ─── Optional: Cloudflare Tunnel ─────────────────────────────────────
# Uncomment to use Cloudflare Tunnel instead of exposing nginx port 80
# Run with: docker compose --profile tunnel up -d
# CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here

# ─── Optional: Nginx port ────────────────────────────────────────────
# Change the port nginx listens on (default: 80)
# NGINX_PORT=80
