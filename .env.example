# ─── Telegram Local Bot API Server ────────────────────────────────────
# Required for Docker deployment. Get from https://my.telegram.org
# The telegram-bot-api container will not become healthy without both values.
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# ─── Optional: Frontend ─────────────────────────────────────────────
# API URL baked into frontend at build time (default: /api)
# Only change if frontend is deployed on a separate server
# NEXT_PUBLIC_API_URL=/api

# ─── Optional: Cloudflare Tunnel ─────────────────────────────────────
# Uncomment to use Cloudflare Tunnel instead of exposing nginx port 80
# Run with: docker compose --profile tunnel up -d
# CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here

# ─── Optional: Nginx port ────────────────────────────────────────────
# Change the port nginx listens on (default: 80)
# NGINX_PORT=80

# ─── Optional: SSL/HTTPS ─────────────────────────────────────────────
# Required for HTTPS access on port 443
# APP_DOMAIN=myapp.example.com

# SSL certs in nginx/ssl/ directory
# If no cert found, a self-signed cert will be auto-generated for APP_DOMAIN
# SSL_CERT_FILE=cert.pem   # Default filename for app cert
# SSL_KEY_FILE=key.pem     # Default key filename

# ─── S3 Domain (Phase 3/6: download + upload redirect) ──────────────
# Separate domain for S3-compatible API (e.g., s3.example.com).
# Nginx creates a server block for this domain. Must also be set in backend/.env.
# Also baked into the frontend at build time so the S3 keys page shows it
# alongside the path-based endpoint. Leave unset to show the path-based only.
# S3_DOMAIN=s3.example.com

# ─── Redis password (REQUIRED) ───────────────────────────────────────
# Docker Compose interpolates ${REDIS_PASSWORD} into the redis --requirepass
# flag and into each service's REDIS_URL (redis://:${REDIS_PASSWORD}@redis:6379).
# Redis holds auth tokens, quota counters, and the upload outstanding counter,
# so it runs with auth and is never exposed to the host/LAN.
# Use a strong random alphanumeric value (avoid URL-special chars so the
# REDIS_URL parses cleanly). Generate one with:
#   openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 40
REDIS_PASSWORD=change-this-to-a-strong-random-secret
