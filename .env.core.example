# ════════════════════════════════════════════════════════════════════════════
# HOST-CORE env — control-plane host (docker-compose.core.yml)
# ════════════════════════════════════════════════════════════════════════════
# Copy to `.env.core` on the control-plane host and fill in. This host runs
# NestJS core, Postgres, Redis, the public edge nginx, and the frontend. The Go
# data plane runs on a SEPARATE host (see .env.transfer.example).
#
# Usage:  docker compose --env-file .env.core -f docker-compose.core.yml up -d
#
# Bring this host up FIRST — the Go host blocks up to 60s waiting for the core
# gRPC server.

# ─── Cross-host wiring (REQUIRED) ─────────────────────────────────────────────
# GO_HOST — host/IP of the Go data-plane host, reachable over the PRIVATE network.
#   Used three ways on this host:
#     - GO_TRANSFER_GRPC_URL = dns:///${GO_HOST}:50051  (NestJS → Go gRPC)
#     - TRANSFER_API_URL     = http://${GO_HOST}:3001   (purge delegation)
#     - GO_UPSTREAM (edge)   = ${GO_HOST}:3001          (data-plane proxy)
#   Must match a SAN entry on the Go leaf cert (re-issue certs before splitting).
GO_HOST=10.0.0.2

# CORE_PRIVATE_IP — the private-NIC IP THIS host binds Redis + the gRPC server to.
#   NEVER 0.0.0.0 (that would expose Redis/gRPC to the public LAN). Redis (6379)
#   and the core gRPC server (50051) bind only here; firewall both to GO_HOST.
CORE_PRIVATE_IP=10.0.0.1

# UPLOAD_BUFFER_NFS — path to the shared upload buffer, mounted on BOTH hosts.
#   Go writes chunks here; NestJS (this host) deletes them on abort/delete and
#   reads directory size for stats. Use the SAME NFS export on both hosts.
#   Example NFS client mount target, or a bind path backed by an NFS mount.
UPLOAD_BUFFER_NFS=/mnt/tele-drive-buffer

# ─── Redis password (REQUIRED) ───────────────────────────────────────────────
# Interpolated into redis --requirepass and every REDIS_URL. The Go host reuses
# the SAME password to connect across the private network. Keep both .env files
# in sync. Generate with:
#   openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 40
REDIS_PASSWORD=change-this-to-a-strong-random-secret

# ─── Public domains / SSL (edge nginx) ────────────────────────────────────────
# APP_DOMAIN — public app domain. Self-signed cert auto-generated if none found.
# APP_DOMAIN=myapp.example.com
# S3_DOMAIN  — dedicated S3-compatible API domain. Must match backend/.env.
# S3_DOMAIN=s3.example.com
# SSL_CERT_FILE=cert.pem
# SSL_KEY_FILE=key.pem

# ─── Optional: edge nginx ports ──────────────────────────────────────────────
# NGINX_PORT=80
# NGINX_SSL_PORT=443

# ─── Optional: scale the data plane across multiple Go hosts ──────────────────
# GO_UPSTREAM — the edge data-plane upstream list. Defaults to "${GO_HOST}:3001"
#   (single Go host). To load-balance the edge across SEVERAL Go hosts, set a
#   comma/space-separated list of host:port — entrypoint-edge.sh expands it into
#   the go_data_plane upstream (round_robin + passive health ejection). Each host
#   runs its own docker-compose.transfer.yml and shares this host's Redis + NFS.
# GO_UPSTREAM=10.0.0.2:3001,10.0.0.3:3001,10.0.0.4:3001

# ─── Optional: frontend ──────────────────────────────────────────────────────
# Baked at build time. Default /api/v1.
# NEXT_PUBLIC_API_URL=/api/v1
